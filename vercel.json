{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "functions": {
    "api/**": { "runtime": "@vercel/node@5.3.21" }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/quizzes/(.*)", "dest": "/api/quizzes/$1" },
    { "src": "/api/quizzes", "dest": "/api/quizzes" },
    { "src": "/api/playtime/(.*)", "dest": "/api/playtime/$1" },
    { "src": "/api/playtime", "dest": "/api/playtime" },
    { "src": "/api/profile/(.*)", "dest": "/api/profile/$1" },
    { "src": "/api/profile", "dest": "/api/profile" },
    { "src": "/api/parent/(.*)", "dest": "/api/parent/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}